# NetDevOps environment variables
# Copy to .env (which is git-ignored) and fill in real values.
# Do NOT commit .env to version control.

# --- SSH credentials for devices ---
NETDEV_USER=netops
NETDEV_PASSWORD=
# Optional enable secret (for Cisco IOS privilege 15)
NETDEV_ENABLE=

# --- NETCONF (ncclient) ---
# Used when connecting to port 830 with NETCONF/YANG
NETCONF_PORT=830

# --- HTTPS / RESTCONF / eAPI ---
# Set a token for token-based APIs (Arista eAPI, Cisco RESTCONF)
NETDEV_API_TOKEN=

# --- MSSQL (mssql-* skills) ---
# Default target database when --database is not passed
DB_NAME=master

# --- Inventory root ---
NETDEV_INVENTORY=inventories/devices.yaml

# --- Backup root ---
NETDEV_BACKUP_ROOT=backups

# --- Logging ---
NETDEV_LOG_LEVEL=INFO
